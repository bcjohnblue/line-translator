# LINE Messaging API 憑證（在 LINE Developers Console 取得）
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# 翻譯引擎設定
# 可選：gemini | groq（未來可加 modal 等）
TRANSLATION_PROVIDER=gemini

# Google Gemini API（在 https://aistudio.google.com/apikey 免費取得）
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest

# Groq API（在 https://console.groq.com 免費取得，免綁信用卡）
# 建議模型：qwen/qwen3-32b（中↔印品質好、每日額度大）
#           llama-3.3-70b-versatile（品質好，但每日 token 額度較小）
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=qwen/qwen3-32b

# 伺服器 port（Cloud Run 會自動注入 PORT，本機預設 8080）
PORT=8080
